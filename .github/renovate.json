{  
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
    "packageRules": [
      {
        "matchDatasources": ["github-releases"],
        "matchRegistryUrls": ["https://github.com/"],
        "matchPackageNames": ["keycloak/keycloak"],
        "automerge": true
      }
    ]
  }