{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "keycloak-totp-admin-api JAR version",
      "managerFilePatterns": ["/(^|/)Containerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>.+?)\\s*ARG TOTP_ADMIN_API_VERSION=(?<currentValue>\\S+)"
      ],
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "kete JAR version",
      "managerFilePatterns": ["/(^|/)Containerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>.+?)\\s*ARG KETE_VERSION=(?<currentValue>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["github-releases"],
      "matchDepNames": ["janus-iam/keycloak-totp-admin-api"],
      "automerge": true,
      "versioning": "semver"
    },
    {
      "matchDatasources": ["github-releases"],
      "matchDepNames": ["FortuneN/kete"],
      "automerge": true
    }
  ]
}
